# ------------------ 🍃 MongoDB -------------------
DB_NAME=software_management_service_db
DB_URL=mongodb://localhost/software_management_service_db

# ------------------ 🔌 Server --------------------
PORT_NUMBER=8082

# ------------------ 🌐 Environment ---------------
NODE_ENV=development

# ------------------ 🔴 Redis Configuration ------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRY_ATTEMPTS=10
REDIS_RETRY_INITIAL_DELAY=100
REDIS_RETRY_MAX_DELAY=2000

# ------------------ ⏳ Global Rate Limiter ------------------
RATE_LIMIT_WINDOW=10
RATE_LIMIT_MAX=100

# ------------------ 📧 Email Configuration (SMTP + Branding) ---
# Gmail SMTP Setup (Get App Password: https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-digit-gmail-app-password

# Email Sender Configuration
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Admin Panel Service

# Branding (Used in email templates)
COMPANY_NAME=Admin Panel Service
COMPANY_LOGO=https://ui-avatars.com/api/?name=Admin+Panel+Service&size=150&background=4f46e5&color=fff&bold=true&fontSize=0.4
SUPPORT_EMAIL=support@yourcompany.com
COMPANY_ADDRESS=Your City, Your Country

# ------------------ Service Token Secrets ------------------
CUSTOM_AUTH_SERVICE_TOKEN_SECRET=your-custom-auth-service-token-secret
SOFTWARE_MANAGEMENT_SERVICE_TOKEN_SECRET=your-software-management-service-token-secret
ADMIN_PANEL_SERVICE_TOKEN_SECRET=your-admin-panel-service-token-secret

# ------------------ Service Names ------------------
CUSTOM_AUTH_SERVICE_NAME=Custom_Auth_Service
SOFTWARE_MANAGEMENT_SERVICE_NAME=Software_Management_Service
ADMIN_PANEL_SERVICE_NAME=Admin_Panel_Service

# Allowed Services
ALLOWED_SERVICE_NAMES=${CUSTOM_AUTH_SERVICE_NAME},${SOFTWARE_MANAGEMENT_SERVICE_NAME},${ADMIN_PANEL_SERVICE_NAME}

SERVICE_TOKEN_EXPIRY=3600

ADMIN_PANEL_SERVICE_URI=http://localhost:8081
CUSTOM_AUTH_SERVICE_URI=http://localhost:8080

# ------------------ Redis ------------------
REDIS_KEY_SALT=your-random-redis-key-salt

# ------------------ Microservice Configuration ------------------
MAKE_IT_MICROSERVICE=true

DEVICE_TYPE=LAPTOP
DEVICE_UUID=00000000-0000-4000-8000-000000000001

SERVICE_INSTANCE_NAME=software-management-service-01

ADVANCED_LOGGING_ENABLED=true
ACTIVITY_TRACKING_ENABLED=true

FIRST_NAME_SETTING=optional

# ------------------ JWT ------------------
ACCESS_TOKEN_SECRET_CODE=your-access-token-secret
REFRESH_TOKEN_SECRET_CODE=your-refresh-token-secret

ACCESS_TOKEN_EXPIRY=6000
REFRESH_TOKEN_EXPIRY=604800

# ------------------ Audit ------------------
AUDIT_MODE=CHANGED_ONLY
AUTH_MODE=EMAIL

FRONTEND_URL=http://localhost:5500

# ------------------ Bulk Import ------------------
DEFAULT_ALLOW_STABILIZING_ROLLBACK=true

REQUIREMENT_BULK_IMPORT_MAX_FILES=10
REQUIREMENT_BULK_IMPORT_MAX_FILE_SIZE_MB=20

# ------------------ Supabase Storage ------------------
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (Never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage bucket
SUPABASE_BUCKET_NAME=bulk-import-files

# Signed URL expiry (seconds)
SUPABASE_SIGNED_URL_EXPIRY=604800

# ------------------ Bulk Import Upload ------------------
# Upload original uploaded file after processing
BULK_IMPORT_UPLOAD_ORIGINAL=false

# Upload processed output/report
BULK_IMPORT_UPLOAD_PROCESSED=true

# Maximum concurrent uploads
BULK_IMPORT_MAX_CONCURRENT_UPLOADS=5